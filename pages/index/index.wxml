<view class="page-root" catchtouchmove="noop" bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
  <view class="profile-bar">
    <view class="profile-picker" bindtap="openProfilePicker">
      <text class="profile-picker-name">{{profiles[activeProfileIndex] ? profiles[activeProfileIndex].name : 'Profile'}}</text>
      <text class="profile-picker-arrow">></text>
    </view>
  </view>

  <view class="tabs">
    <view class="tab {{currentTab==='exam' ? 'active' : ''}}" data-tab="exam" bindtap="switchTab">Exams</view>
    <view class="tab {{currentTab==='trend' ? 'active' : ''}}" data-tab="trend" bindtap="switchTab">Charts</view>
    <view class="tab {{currentTab==='settings' ? 'active' : ''}}" data-tab="settings" bindtap="switchTab">Settings</view>
  </view>

  <view class="main-content {{_slideDirection==='left' ? 'slide-out-left' : ''}} {{_slideDirection==='right' ? 'slide-out-right' : ''}}">
    <block wx:if="{{currentTab==='exam'}}">
      <view class="tab-content">
        <block wx:if="{{exams.length}}">
          <block wx:for="{{exams}}" wx:key="id">
            <view class="exam-card {{currentExamId===item.id ? 'is-active' : ''}} {{item.excluded ? 'is-excluded' : ''}}">
              <view class="exam-header" data-id="{{item.id}}" bindtap="selectExam">
                <view class="exam-info">
                  <view class="exam-name">{{item.name}}</view>
                  <view class="exam-meta">
                    <text>{{item.startDate || 'No date'}}</text>
                    <text class="exam-total-meta">Total {{item.totalScore}}</text>
                  </view>
                </view>
                <view class="exam-actions">
                  <view class="exam-edit-btn" data-id="{{item.id}}" catchtap="openExamModal">Edit</view>
                </view>
              </view>

              <block wx:if="{{currentExamId===item.id}}">
                <view class="exam-subjects">
                  <block wx:if="{{item.subjects && item.subjects.length}}">
                    <block wx:for="{{item.subjects}}" wx:key="name">
                      <view class="subject-row" data-index="{{index}}" bindtap="editSubject">
                        <view class="subject-row-left">
                          <view class="subject-dot"></view>
                          <text class="subject-row-name">{{item.name}}</text>
                        </view>
                        <view class="subject-row-right">
                          <text class="subject-row-score">{{item.score}}</text>
                          <text class="subject-row-full">/ {{item.fullScore || 100}}</text>
                        </view>
                      </view>
                    </block>
                  </block>
                  <block wx:else>
                    <view class="empty-hint">No subjects yet.</view>
                  </block>
                </view>
                <view class="detail-panel-actions">
                  <view class="detail-action-btn" bindtap="openScoreModal">Add Subject</view>
                  <view class="detail-action-btn" bindtap="openBatchModal">Batch Fill</view>
                  <view class="detail-action-btn" bindtap="openShareExamReport">Share</view>
                </view>
              </block>
            </view>
          </block>
        </block>
        <block wx:else>
          <view class="empty-state">
            <view class="empty-text">No exams yet</view>
            <view class="empty-hint">Create your first exam below</view>
          </view>
        </block>
        <view class="new-exam-btn" bindtap="openExamModal">+ New Exam</view>
      </view>
    </block>

    <block wx:elif="{{currentTab==='trend'}}">
      <view class="tab-content">
        <view class="card">
          <view class="card-title">Charts</view>
          <view class="analysis-tabs">
            <view class="analysis-tab {{analysisMode==='score' ? 'active' : ''}}" data-mode="score" bindtap="switchAnalysisMode">Score</view>
            <view class="analysis-tab {{analysisMode==='rank' ? 'active' : ''}}" data-mode="rank" bindtap="switchAnalysisMode">Rank</view>
            <view class="analysis-tab {{analysisMode==='radar' ? 'active' : ''}}" data-mode="radar" bindtap="switchAnalysisMode">Radar</view>
          </view>

          <block wx:if="{{analysisMode!=='radar'}}">
            <scroll-view class="chart-tabs-scroll" scroll-x="true" enable-flex="true">
              <view class="chart-tabs-inner">
                <view class="chart-tab {{selectedChartSubject==='' ? 'active' : ''}}" data-subject="" bindtap="selectChartSubject">All</view>
                <block wx:for="{{subjectNames}}" wx:key="*this">
                  <view class="chart-tab {{selectedChartSubject===item ? 'active' : ''}}" data-subject="{{item}}" bindtap="selectChartSubject">{{item}}</view>
                </block>
              </view>
            </scroll-view>

            <block wx:if="{{analysisMode==='rank'}}">
              <view class="rank-type-row">
                <view class="rank-type-option {{rankType==='class' ? 'active' : ''}}" data-type="class" bindtap="switchRankType">Class</view>
                <view class="rank-type-option {{rankType==='grade' ? 'active' : ''}}" data-type="grade" bindtap="switchRankType">Grade</view>
              </view>
            </block>

            <view class="card chart-card">
              <view class="chart-zoom-btn" data-type="trend" bindtap="openChartZoom">Zoom</view>
              <canvas canvas-id="trendChart" id="trendChart" class="trend-canvas"></canvas>
              <block wx:if="{{trendEmpty}}">
                <view class="chart-empty"><view class="chart-empty-text">No chart data</view></view>
              </block>
            </view>
          </block>

          <block wx:else>
            <view class="radar-title">
              <text wx:if="{{currentExam}}">Current: <text class="radar-current-name" bindtap="switchCurrentExam">{{currentExam.name}}</text></text>
              <text wx:else>Current: none</text>
            </view>
            <view class="radar-compare">
              <view class="radar-compare-chips">
                <block wx:for="{{radarExams}}" wx:key="id">
                  <view class="compare-chip {{item.isCurrent ? 'current' : ''}} {{item.selected ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="onRadarExamTap">{{item.name}}</view>
                </block>
              </view>
              <view class="radar-hint">Tap current exam to switch, tap others to compare.</view>
            </view>
            <view class="card chart-card">
              <view class="chart-zoom-btn" data-type="radar" bindtap="openChartZoom">Zoom</view>
              <canvas canvas-id="radarChart" id="radarChart" class="radar-canvas"></canvas>
              <block wx:if="{{radarEmpty}}">
                <view class="chart-empty"><view class="chart-empty-text">{{radarEmptyText}}</view></view>
              </block>
            </view>
          </block>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="tab-content">
        <view class="card">
          <view class="card-title">Cloud Account</view>
          <view class="auth-settings-card">
            <view class="auth-settings-main {{isLoggedIn ? 'is-clickable' : ''}}" bindtap="openNicknameModal">
              <view wx:if="{{isLoggedIn}}" class="auth-settings-hint">Tap to edit nickname</view>
              <view class="auth-settings-name">{{authDisplayName}}</view>
              <view class="auth-settings-desc">{{authDisplayDesc}}</view>
            </view>
            <view class="auth-settings-actions">
              <view wx:if="{{!isLoggedIn}}" class="setting-btn green" bindtap="openAuthModal">Login</view>
              <view wx:else class="setting-btn" bindtap="logout">Logout</view>
            </view>
          </view>
          <block wx:if="{{isLoggedIn}}">
            <view class="setting-row">
              <view class="setting-row-left">
                <view class="setting-label">Auto Sync</view>
                <view class="setting-desc">Enabled for the current account.</view>
              </view>
              <view class="setting-btn is-disabled">On</view>
            </view>
            <view class="setting-row">
              <view class="setting-row-left">
                <view class="setting-label">Recycle Bin</view>
                <view class="setting-desc">Restore deleted profiles from cloud.</view>
              </view>
              <view class="setting-btn" bindtap="openRecycleBin">Open</view>
            </view>
            <block wx:if="{{syncStatusMessage}}">
              <view class="auth-status {{syncStatusType}}">{{syncStatusMessage}}</view>
            </block>
          </block>
        </view>

        <view class="card">
          <view class="card-title">Profiles</view>
          <view class="setting-desc">Each profile stores a separate exam history.</view>
          <view class="profile-list">
            <block wx:for="{{profiles}}" wx:key="id">
              <view class="profile-item {{activeProfileIndex===index ? 'is-active' : ''}}">
                <view class="profile-item-info" data-index="{{index}}" bindtap="switchToProfile">
                  <view class="profile-item-name">
                    <text>{{item.name}}</text>
                    <text wx:if="{{activeProfileIndex===index}}" class="active-badge">Current</text>
                  </view>
                  <view class="profile-item-meta">{{item.examCount || 0}} records</view>
                </view>
                <view class="profile-item-actions">
                  <view class="profile-share-btn" data-index="{{index}}" bindtap="openShareProfileReport">Share</view>
                  <view class="profile-action-btn rename-btn" data-index="{{index}}" bindtap="renameProfile"><text class="icon-pencil">E</text><text class="icon-corner">.</text></view>
                  <view wx:if="{{profiles.length>1}}" class="profile-action-btn danger" data-index="{{index}}" bindtap="confirmDeleteProfile">X</view>
                </view>
              </view>
            </block>
          </view>
          <view class="add-profile-area">
            <view wx:if="{{!showAddProfile}}" class="add-profile-btn" bindtap="showAddProfileInput">+ New Profile</view>
            <view wx:else class="add-profile-input-row">
              <input class="add-profile-input" placeholder="Profile name" maxlength="20" value="{{newProfileName}}" bindinput="onNewProfileInput" bindconfirm="confirmAddProfile" focus="{{true}}" />
              <view class="add-profile-confirm" bindtap="confirmAddProfile">OK</view>
              <view class="add-profile-cancel" bindtap="cancelAddProfile">Cancel</view>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">Data</view>
          <view class="setting-row">
            <view class="setting-row-left"><view class="setting-label">Demo Data</view><view class="setting-desc">Inject sample exams.</view></view>
            <view class="setting-btn green" bindtap="addDemoData">Add</view>
          </view>
          <view class="setting-row">
            <view class="setting-row-left"><view class="setting-label">Export</view><view class="setting-desc">Export to Excel.</view></view>
            <view class="setting-btn" bindtap="exportData">Export</view>
          </view>
          <view class="setting-row">
            <view class="setting-row-left"><view class="setting-label">Import</view><view class="setting-desc">Import from Excel.</view></view>
            <view class="setting-btn" bindtap="importData">Import</view>
          </view>
        </view>
      </view>
    </block>
  </view>
