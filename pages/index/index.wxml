<view class="modal-mask" wx:if="{{showConfirmModal}}" bindtap="closeConfirmModal">
  <view class="modal confirm-modal" catchtap="noop">
    <view class="confirm-icon-wrap {{confirmIconType}}">
      <text>{{confirmIcon}}</text>
    </view>
    <view class="confirm-title">{{confirmTitle}}</view>
    <view class="confirm-message">{{confirmMessage}}</view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeConfirmModal" wx:if="{{confirmShowCancel}}">取消</view>
      <view class="btn {{confirmOkClass}}" bindtap="onConfirmOk" wx:if="{{confirmOkText}}">{{confirmOkText}}</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showReportModal}}" bindtap="closeReportModal">
  <view class="modal report-modal" catchtap="noop">
    <view class="modal-header">
      <view class="modal-title">报告预览</view>
      <view class="modal-close" bindtap="closeReportModal">×</view>
    </view>
    <view class="report-preview">
      <canvas canvas-id="reportCanvas" id="reportCanvas" class="report-canvas" style="height:{{reportCanvasHeight || 800}}px;width:375px;" wx:if="{{!reportImage}}"></canvas>
      <image wx:if="{{reportImage}}" src="{{reportImage}}" mode="widthFix" class="report-image" show-menu-by-longpress="true"></image>
      <view class="report-loading" wx:if="{{reportLoading}}">
        <view class="report-loading-text">正在生成报告...</view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeReportModal">关闭</view>
      <view class="btn btn-download" bindtap="saveReport" wx:if="{{reportImage}}">保存图片</view>
      <view class="btn btn-share" bindtap="shareReport" wx:if="{{reportImage}}">转发</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showRenameModal}}" bindtap="closeRenameModal">
  <view class="modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">重命名档案</view>
      <view class="modal-close" bindtap="closeRenameModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <input class="form-input" placeholder="请输入新的档案名称" maxlength="20" value="{{renameValue}}" bindinput="onRenameInput" focus="{{true}}" bindconfirm="confirmRename" />
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeRenameModal">取消</view>
      <view class="btn btn-primary" bindtap="confirmRename">确定</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showChartZoom}}" bindtap="closeChartZoom">
  <view class="modal chart-zoom-modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">{{chartZoomTitle}}</view>
      <view class="modal-close" bindtap="closeChartZoom">×</view>
    </view>
    <view class="modal-body chart-zoom-body">
      <block wx:if="{{chartZoomType === 'trend'}}">
        <scroll-view scroll-x class="chart-tabs-scroll">
          <view class="chart-tabs-inner">
            <view class="chart-tab {{zoomSelectedSubject === '' ? 'active' : ''}}" bindtap="zoomSelectSubject" data-subject="">总分</view>
            <view class="chart-tab {{zoomSelectedSubject === item ? 'active' : ''}}"
              wx:for="{{subjectNames}}" wx:key="*this" bindtap="zoomSelectSubject" data-subject="{{item}}">{{item}}</view>
          </view>
        </scroll-view>

        <view class="rank-type-row" wx:if="{{analysisMode === 'rank'}}">
          <view class="rank-type-option {{zoomRankType === 'class' ? 'active' : ''}}" bindtap="zoomSwitchRankType" data-type="class">班级排名</view>
          <view class="rank-type-option {{zoomRankType === 'grade' ? 'active' : ''}}" bindtap="zoomSwitchRankType" data-type="grade">年级排名</view>
        </view>

        <canvas canvas-id="zoomTrendChart" id="zoomTrendChart" class="zoom-trend-canvas"></canvas>
      </block>

      <block wx:if="{{chartZoomType === 'radar'}}">
        <view class="radar-title">当前考试：<text class="radar-current-name">{{currentExam ? currentExam.name : '未选择'}}</text></view>
        <canvas canvas-id="zoomRadarChart" id="zoomRadarChart" class="zoom-radar-canvas"></canvas>
      </block>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showBatchModal}}" bindtap="closeBatchModal">
  <view class="modal batch-modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">批量填写成绩</view>
      <view class="modal-close" bindtap="closeBatchModal">×</view>
    </view>
    <scroll-view scroll-y class="batch-body" catchtap="noop">
      <view class="batch-header">
        <view class="batch-col batch-col-name">科目</view>
        <view class="batch-col batch-col-score">成绩</view>
        <view class="batch-col batch-col-rank">班排</view>
        <view class="batch-col batch-col-rank">年排</view>
        <view class="batch-col batch-col-del"></view>
      </view>

      <view class="batch-row" wx:for="{{batchList}}" wx:key="index">
        <view class="batch-col batch-col-name">
          <input class="batch-input batch-name-input" placeholder="科目" value="{{item.name}}" bindinput="onBatchInput" data-index="{{index}}" data-field="name" />
        </view>
        <view class="batch-col batch-col-score">
          <input class="batch-input" type="number" placeholder="成绩" value="{{item.score}}" bindinput="onBatchInput" data-index="{{index}}" data-field="score" />
        </view>
        <view class="batch-col batch-col-rank">
          <input class="batch-input" type="number" placeholder="可选" value="{{item.classRank}}" bindinput="onBatchInput" data-index="{{index}}" data-field="classRank" />
        </view>
        <view class="batch-col batch-col-rank">
          <input class="batch-input" type="number" placeholder="可选" value="{{item.gradeRank}}" bindinput="onBatchInput" data-index="{{index}}" data-field="gradeRank" />
        </view>
        <view class="batch-col batch-col-del">
          <view class="batch-del-btn" bindtap="removeBatchSubject" data-index="{{index}}">删</view>
        </view>
      </view>

      <view class="batch-add-row">
        <input class="batch-input batch-add-input" placeholder="新科目" value="{{newBatchSubject}}" bindinput="onNewBatchInput" bindconfirm="addBatchSubject" />
        <view class="batch-add-btn" bindtap="addBatchSubject">+ 添加</view>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeBatchModal">取消</view>
      <view class="btn btn-primary" bindtap="saveBatch">全部保存</view>
    </view>
  </view>
</view>

<!-- 登录弹窗 -->
<view class="modal-mask" wx:if="{{showAuthModal}}" bindtap="closeAuthModal">
  <view class="modal auth-modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">{{authTitle}}</view>
      <view class="modal-close" bindtap="closeAuthModal">×</view>
    </view>
    <scroll-view scroll-y class="auth-modal-body">
      <!-- 账号输入 -->
      <view class="form-group">
        <view class="form-label">邮箱 / 手机号</view>
        <input class="form-input" placeholder="请输入邮箱或手机号" value="{{authAccount}}" bindinput="onAuthInput" data-field="account" maxlength="100" />
      </view>

      <!-- 密码区域（默认展示） -->
      <view class="form-group" wx:if="{{authShowPasswordSection}}">
        <view class="form-label">密码</view>
        <view class="auth-password-wrap">
          <input class="form-input auth-password-input" placeholder="{{authMode === 'register' ? '设置密码（至少6位）' : '请输入密码'}}" 
            password="{{!authPasswordVisible}}" value="{{authPassword}}" bindinput="onAuthInput" data-field="password" maxlength="64" />
          <view class="auth-pwd-toggle" bindtap="toggleAuthPasswordVisible" data-field="password">
            <text>{{authPasswordVisible ? '🙈' : '👁'}}</text>
          </view>
        </view>
      </view>

      <!-- 验证码区域 -->
      <view class="form-group" wx:if="{{authShowCodeSection}}">
        <view class="form-label">验证码</view>
        <view class="auth-code-row">
          <input class="form-input auth-code-input" type="number" placeholder="6位验证码" value="{{authCode}}" bindinput="onAuthInput" data-field="code" maxlength="6" />
          <view class="auth-send-code-btn {{authSendingCode || authCountdown > 0 ? 'disabled' : ''}}" bindtap="handleSendCode">
            {{authSendingCode ? '发送中…' : (authCountdown > 0 ? authCountdown + 's' : '发送验证码')}}
          </view>
        </view>
      </view>

      <!-- 找回密码专用 -->
      <block wx:if="{{authShowResetSection}}">
        <view class="form-group">
          <view class="form-label">新密码</view>
          <view class="auth-password-wrap">
            <input class="form-input auth-password-input" placeholder="至少6位" password="{{!authNewPasswordVisible}}" value="{{authNewPassword}}" bindinput="onAuthInput" data-field="newPassword" maxlength="64" />
            <view class="auth-pwd-toggle" bindtap="toggleAuthPasswordVisible" data-field="newPassword">
              <text>{{authNewPasswordVisible ? '🙈' : '👁'}}</text>
            </view>
          </view>
        </view>
        <view class="form-group">
          <view class="form-label">确认新密码</view>
          <view class="auth-password-wrap">
            <input class="form-input auth-password-input" placeholder="再次输入" password="{{!authConfirmPasswordVisible}}" value="{{authConfirmPassword}}" bindinput="onAuthInput" data-field="confirmPassword" maxlength="64" />
            <view class="auth-pwd-toggle" bindtap="toggleAuthPasswordVisible" data-field="confirmPassword">
              <text>{{authConfirmPasswordVisible ? '🙈' : '👁'}}</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 提交按钮 -->
      <view class="auth-submit-area">
        <view class="btn btn-primary auth-submit-btn {{authSubmitting ? 'disabled' : ''}}" bindtap="handleAuthSubmit">
          {{authSubmitting ? '处理中…' : authSubmitText}}
        </view>
      </view>

      <!-- 底部操作链接 -->
      <view class="auth-footer-links">
        <view class="auth-link" wx:if="{{authShowSmsLink}}" bindtap="switchToSmsLogin">📨 验证码登录</view>
        <view class="auth-link" wx:if="{{authShowLoginLink}}" bindtap="switchToPasswordLogin">🔑 密码登录</view>
        <view class="auth-link" wx:if="{{authShowRegisterLink}}" bindtap="switchToRegister">📝 注册账号</view>
        <view class="auth-link" wx:if="{{authShowResetLink}}" bindtap="switchToResetPwd">忘记密码？</view>
        <view class="auth-link" wx:if="{{authMode !== 'login'}}" bindtap="switchToPasswordLogin">← 返回登录</view>
      </view>

      <!-- 状态提示 -->
      <view class="auth-status-msg {{authStatusType}}" wx:if="{{authStatusMessage}}">{{authStatusMessage}}</view>
    </scroll-view>
  </view>
</view>

<!-- 修改昵称弹窗 -->
<view class="modal-mask" wx:if="{{showNicknameModal}}" bindtap="closeNicknameModal">
  <view class="modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">✏️ 修改昵称</view>
      <view class="modal-close" bindtap="closeNicknameModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <input class="form-input" placeholder="输入新昵称" maxlength="20" value="{{nicknameValue}}" bindinput="onNicknameInput" focus="{{true}}" />
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeNicknameModal">取消</view>
      <view class="btn btn-primary {{nicknameSaving ? 'disabled' : ''}}" bindtap="saveNickname">{{nicknameSaving ? '保存中…' : '保存'}}</view>
    </view>
  </view>
</view>

<!-- 回收站弹窗 -->
<view class="modal-mask" wx:if="{{showRecycleBinPicker}}" bindtap="closeRecycleBin">
  <view class="modal recycle-modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">🗑️ 回收站</view>
      <view class="modal-close" bindtap="closeRecycleBin">×</view>
    </view>
    <scroll-view scroll-y class="recycle-body">
      <view class="recycle-subtitle">已删除的档案可在此恢复，超过30天将自动彻底删除。</view>

      <view class="recycle-loading" wx:if="{{recycleBusy}}">
        <text>正在读取回收站…</text>
      </view>

      <view class="recycle-empty" wx:elif="{{deletedCloudProfiles.length === 0}}">
        <view class="recycle-empty-icon">🗑️</view>
        <view class="recycle-empty-text">回收站是空的</view>
      </view>

      <block wx:else>
        <view class="recycle-list">
          <view class="recycle-item" wx:for="{{deletedCloudProfiles}}" wx:key="profileId">
            <view class="recycle-item-check">
              <view class="recycle-checkbox {{item._selected ? 'checked' : ''}}" bindtap="toggleDeletedProfile" data-index="{{index}}"></view>
            </view>
            <view class="recycle-item-main">
              <view class="recycle-item-name">{{item.profileName}}</view>
              <view class="recycle-item-meta">{{item.examCount}} 场考试 · {{item._dataSize}}</view>
              <view class="recycle-item-time">删除时间：{{item._deletedAt}} · 剩余 {{item._daysLeft}} 天</view>
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
    <view class="modal-footer" wx:if="{{deletedCloudProfiles.length > 0}}">
      <view class="btn btn-secondary" bindtap="closeRecycleBin">关闭</view>
      <view class="btn btn-primary" bindtap="restoreDeletedProfiles" disabled="{{recycleBusy}}">恢复选中</view>
      <view class="btn btn-danger" bindtap="purgeDeletedProfiles" disabled="{{recycleBusy}}">彻底删除</view>
    </view>
    <view class="modal-footer" wx:else>
      <view class="btn btn-secondary" bindtap="closeRecycleBin">关闭</view>
    </view>
  </view>
</view>
