<wxs module="scoreUtil">
module.exports.getRate = function(score, fullScore) {
  if (fullScore) {
    var rate = score / fullScore * 100;
    return rate.toFixed(1);
  }
  return '--';
}
module.exports.getRateClass = function(score) {
  if (score >= 90) return 'good';
  if (score >= 60) return 'normal';
  return 'bad';
}
</wxs>

<view class="profile-bar" wx:if="{{profiles.length > 1}}">
  <picker range="{{profileNames}}" value="{{activeProfileIndex}}" bindchange="onProfileSwitch">
    <view class="profile-picker">
      <text class="profile-picker-name">{{profiles[activeProfileIndex].name}}</text>
      <text class="profile-picker-arrow">v</text>
    </view>
  </picker>
</view>

<view class="tabs">
  <view class="tab {{currentTab === 'exam' ? 'active' : ''}}" bindtap="switchTab" data-tab="exam">考试详情</view>
  <view class="tab {{currentTab === 'trend' ? 'active' : ''}}" bindtap="switchTab" data-tab="trend">成绩分析</view>
  <view class="tab {{currentTab === 'settings' ? 'active' : ''}}" bindtap="switchTab" data-tab="settings">设置</view>
</view>

<view class="main-content {{_slideDirection === 'left' ? 'slide-out-left' : ''}} {{_slideDirection === 'right' ? 'slide-out-right' : ''}}"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd">

  <view class="tab-content" wx:if="{{currentTab === 'exam'}}">
    <view class="empty-state" wx:if="{{exams.length === 0}}">
      <view class="empty-icon">📘</view>
      <view class="empty-text">暂无考试记录</view>
      <view class="empty-hint">点击下方按钮新建考试</view>
    </view>

    <scroll-view scroll-y class="exam-scroll" wx:else>
      <view class="exam-card {{item.excluded ? 'is-excluded' : ''}} {{currentExamId === item.id ? 'is-active' : ''}}"
        wx:for="{{exams}}" wx:key="id" bindtap="selectExam" data-id="{{item.id}}">
        <view class="exam-header">
          <view class="exam-info">
            <view class="exam-name">{{item.name}}</view>
            <view class="exam-meta">
              <text wx:if="{{item.startDate}}">{{item.startDate}}</text>
              <text wx:if="{{item.startDate}}"> · </text>
              <text>{{item.totalScore}}分</text>
            </view>
          </view>
          <view class="exam-badges">
            <view class="badge" wx:if="{{item.excluded}}" style="background:#fee;color:#e88a8a;">已排除</view>
            <view class="badge" wx:if="{{item.totalClassRank}}" style="background:rgba(124,169,201,0.12);color:#7ca9c9;">班{{item.totalClassRank}}</view>
            <view class="badge" wx:if="{{item.totalGradeRank}}" style="background:rgba(155,141,196,0.12);color:#9b8dc4;">年{{item.totalGradeRank}}</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="new-exam-btn" bindtap="openExamModal">
      <text>+ 新建考试</text>
    </view>
  </view>

  <view class="tab-content" wx:if="{{currentTab === 'trend'}}">
    <view class="analysis-tabs">
      <view class="analysis-tab {{analysisMode === 'score' ? 'active' : ''}}" bindtap="switchAnalysisMode" data-mode="score">分数趋势</view>
      <view class="analysis-tab {{analysisMode === 'rank' ? 'active' : ''}}" bindtap="switchAnalysisMode" data-mode="rank">排名趋势</view>
      <view class="analysis-tab {{analysisMode === 'radar' ? 'active' : ''}}" bindtap="switchAnalysisMode" data-mode="radar">科目对比</view>
    </view>

    <view class="card chart-card" wx:if="{{analysisMode === 'score' || analysisMode === 'rank'}}">
      <view class="chart-zoom-btn" bindtap="openChartZoom" data-type="trend">放大</view>

      <scroll-view scroll-x class="chart-tabs-scroll">
        <view class="chart-tabs-inner">
          <view class="chart-tab {{selectedChartSubject === '' ? 'active' : ''}}" bindtap="selectChartSubject" data-subject="">总分</view>
          <view class="chart-tab {{selectedChartSubject === item ? 'active' : ''}}"
            wx:for="{{subjectNames}}" wx:key="*this" bindtap="selectChartSubject" data-subject="{{item}}">{{item}}</view>
        </view>
      </scroll-view>

      <view class="rank-type-row" wx:if="{{analysisMode === 'rank'}}">
        <view class="rank-type-option {{rankType === 'class' ? 'active' : ''}}" bindtap="switchRankType" data-type="class">班级排名</view>
        <view class="rank-type-option {{rankType === 'grade' ? 'active' : ''}}" bindtap="switchRankType" data-type="grade">年级排名</view>
      </view>

      <canvas canvas-id="trendChart" id="trendChart" class="trend-canvas"></canvas>

      <view class="chart-empty" wx:if="{{trendEmpty}}">
        <view class="chart-empty-icon">{{analysisMode === 'rank' ? '📉' : '📈'}}</view>
        <view class="chart-empty-text">{{analysisMode === 'rank' ? '暂无排名数据' : '暂无成绩数据'}}</view>
      </view>
    </view>

    <view class="card chart-card" wx:if="{{analysisMode === 'radar'}}">
      <view class="chart-zoom-btn" bindtap="openChartZoom" data-type="radar">放大</view>
      <view class="radar-title">当前：<text class="radar-current-name">{{currentExam ? currentExam.name : '未选择'}}</text></view>

      <view class="radar-compare" wx:if="{{radarExams.length > 0}}">
        <view class="radar-compare-chips">
          <view class="compare-chip {{item.isCurrent ? 'current' : ''}} {{item.selected ? 'selected' : ''}} {{item.isCurrent ? '' : (selectedCompareCount >= 2 && !item.selected ? 'disabled' : '')}}"
            wx:for="{{radarExams}}" wx:key="id" bindtap="onRadarExamTap" data-id="{{item.id}}">
            {{item.name}}
          </view>
        </view>
        <view class="radar-hint">橙色是当前考试，其余最多选择两场作为对比</view>
      </view>

      <canvas canvas-id="radarChart" id="radarChart" class="radar-canvas"></canvas>

      <view class="radar-summary" wx:if="{{radarBest && radarWorst && !radarEmpty}}">
        <view class="radar-summary-item best">
          <text class="radar-summary-icon">强</text>
          <text class="radar-summary-label">最佳</text>
          <text class="radar-summary-name">{{radarBest.name}}</text>
          <text class="radar-summary-detail">{{radarBest.score}}/{{radarBest.fullScore}}</text>
          <text class="radar-summary-rate best-rate">{{radarBest.rate}}%</text>
        </view>
        <view class="radar-summary-item worst">
          <text class="radar-summary-icon">弱</text>
          <text class="radar-summary-label">薄弱</text>
          <text class="radar-summary-name">{{radarWorst.name}}</text>
          <text class="radar-summary-detail">{{radarWorst.score}}/{{radarWorst.fullScore}}</text>
          <text class="radar-summary-rate worst-rate">{{radarWorst.rate}}%</text>
        </view>
      </view>

      <view class="chart-empty" wx:if="{{radarEmpty}}">
        <view class="chart-empty-icon">🕸</view>
        <view class="chart-empty-text">{{radarEmptyText}}</view>
      </view>
    </view>
  </view>

  <view class="tab-content" wx:if="{{currentTab === 'settings'}}">
    <view class="card">
      <view class="card-title">档案管理</view>
      <view class="setting-desc">每个档案都是独立的数据空间，可以分别记录不同学生或不同阶段的成绩。</view>

      <view class="profile-list">
        <view class="profile-item {{profiles[activeProfileIndex].id === item.id ? 'is-active' : ''}}"
          wx:for="{{profiles}}" wx:key="id" bindtap="switchToProfile" data-index="{{index}}">
          <view class="profile-item-info">
            <view class="profile-item-name">
              {{item.name}}
              <view class="active-badge" wx:if="{{profiles[activeProfileIndex].id === item.id}}">当前</view>
            </view>
            <view class="profile-item-meta">{{item.examCount}} 场考试</view>
          </view>
          <view class="profile-item-actions" catchtap="">
            <view class="profile-share-btn" bindtap="openShareProfileReport" data-index="{{index}}">分享报告</view>
            <view class="profile-action-btn" bindtap="renameProfile" data-index="{{index}}">改名</view>
            <view class="profile-action-btn danger" wx:if="{{profiles.length > 1}}" bindtap="confirmDeleteProfile" data-index="{{index}}">删</view>
          </view>
        </view>
      </view>

      <view class="add-profile-area">
        <view class="add-profile-btn" wx:if="{{!showAddProfile}}" bindtap="showAddProfileInput">+ 新建档案</view>
        <view class="add-profile-input-row" wx:else>
          <input class="add-profile-input" placeholder="New profile name" maxlength="20" value="{{newProfileName}}" bindinput="onNewProfileInput" bindconfirm="confirmAddProfile" focus="{{true}}" />
          <view class="add-profile-confirm" bindtap="confirmAddProfile">确定</view>
          <view class="add-profile-cancel" bindtap="cancelAddProfile">取消</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">数据管理</view>

      <view class="setting-row">
        <view class="setting-row-left">
          <view class="setting-label">添加示例数据</view>
          <view class="setting-desc">向当前档案中添加演示用考试数据</view>
        </view>
        <view class="setting-btn green" bindtap="addDemoData">添加</view>
      </view>

      <view class="setting-row">
        <view class="setting-row-left">
          <view class="setting-label">导出数据</view>
          <view class="setting-desc">导出为 Excel 文件</view>
        </view>
        <view class="setting-btn" bindtap="exportData">导出</view>
      </view>

      <view class="setting-row">
        <view class="setting-row-left">
          <view class="setting-label">导入数据</view>
          <view class="setting-desc">从 Excel 文件导入</view>
        </view>
        <view class="setting-btn" bindtap="importData">导入</view>
      </view>
    </view>
  </view>

</view>

<view class="detail-mask" wx:if="{{showDetailPanel && currentExam}}" bindtap="closeDetailPanel" catchtouchmove=""></view>
<view class="detail-panel {{_panelSlidingOut ? 'panel-slide-out-left' : ''}}" wx:if="{{showDetailPanel && currentExam}}"
  bindtouchstart="onPanelTouchStart" bindtouchmove="onPanelTouchMove" bindtouchend="onPanelTouchEnd">
  <view class="detail-panel-header">
    <view class="detail-panel-handle"></view>
    <view class="detail-panel-title">{{currentExam.name}}</view>
    <view class="detail-panel-summary">
      <text class="detail-panel-score">{{currentExam.totalScore}}分</text>
      <text class="rank-tag" wx:if="{{currentExam.totalClassRank}}">班{{currentExam.totalClassRank}}</text>
      <text class="rank-tag" wx:if="{{currentExam.totalGradeRank}}">年{{currentExam.totalGradeRank}}</text>
    </view>
    <view class="detail-panel-actions">
      <view class="detail-action-btn" catchtap="toggleExclude" data-id="{{currentExam.id}}">{{currentExam.excluded ? '恢复统计' : '排除统计'}}</view>
      <view class="detail-action-btn" catchtap="openExamModal" data-id="{{currentExam.id}}">编辑</view>
      <view class="detail-action-btn danger" catchtap="deleteExam" data-id="{{currentExam.id}}">删除</view>
    </view>
  </view>
  <scroll-view scroll-y class="detail-panel-body">
    <view class="share-btn" bindtap="openShareExamReport">分享考试报告</view>

    <view class="exam-date" wx:if="{{currentExam.startDate}}">
      {{currentExam.startDate}}{{currentExam.endDate && currentExam.endDate !== currentExam.startDate ? ' ~ ' + currentExam.endDate : ''}}
    </view>
    <view class="exam-notes" wx:if="{{currentExam.notes}}">{{currentExam.notes}}</view>

    <view class="card">
      <view class="card-title-row">
        <view class="card-title">各科成绩</view>
        <view class="batch-inline-btn" catchtap="openBatchModal">批量填写</view>
      </view>
      <view class="subject-cards">
        <view class="subject-card" wx:for="{{currentExam.subjects}}" wx:key="name" data-index="{{index}}" bindtap="editSubject">
          <view class="subject-card-name">{{item.name}}</view>
          <view class="subject-card-score {{item.score >= 90 ? 'good' : (item.score >= 60 ? 'normal' : 'bad')}}">{{item.score}}</view>
          <view class="subject-card-rank" wx:if="{{item.classRank || item.gradeRank}}">
            <text class="rank-tag" wx:if="{{item.classRank}}">班{{item.classRank}}</text>
            <text class="rank-tag" wx:if="{{item.gradeRank}}">年{{item.gradeRank}}</text>
          </view>
        </view>

        <view class="subject-card delete-subject-btn" wx:if="{{currentExam.subjects.length > 0}}" catchtap="confirmDeleteSubject">
          <view class="subject-card-name" style="color:var(--accent-danger);">删除科目</view>
          <view class="subject-card-score normal" style="font-size:24rpx;">选择后删除</view>
        </view>

        <view class="add-subject-btn" bindtap="openScoreModal">
          <text style="font-size:48rpx;">+</text>
          <text>添加成绩</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

<view class="score-view-mask" wx:if="{{showScoreView && currentExam}}" bindtap="closeScoreView" catchtouchmove=""></view>
<view class="score-view {{showScoreView ? 'score-view-in' : 'score-view-out'}}" wx:if="{{showScoreView && currentExam}}">
  <view class="score-view-header" catchtouchmove="">
    <view class="score-view-back" bindtap="closeScoreView">返回</view>
    <view class="score-view-title">{{currentExam.name}} - 各科成绩</view>
    <view class="score-view-summary">
      <text class="detail-panel-score">{{currentExam.totalScore}}分</text>
      <text class="rank-tag" wx:if="{{currentExam.totalClassRank}}">班{{currentExam.totalClassRank}}</text>
      <text class="rank-tag" wx:if="{{currentExam.totalGradeRank}}">年{{currentExam.totalGradeRank}}</text>
    </view>
  </view>
  <scroll-view scroll-y class="score-view-body">
    <view class="card">
      <view class="card-title-row">
        <view class="card-title">各科成绩</view>
        <view class="batch-inline-btn" catchtap="openBatchModal">批量填写</view>
      </view>
      <view class="score-view-cards">
        <view class="score-view-card" wx:for="{{currentExam.subjects}}" wx:key="name" data-index="{{index}}" bindtap="editSubject">
          <view class="score-view-card-name">{{item.name}}</view>
          <view class="score-view-card-score-wrap">
            <text class="score-view-card-score">{{item.score}}</text>
            <text class="score-view-card-full" wx:if="{{item.fullScore}}">/{{item.fullScore}}</text>
          </view>
          <view class="score-view-card-rate {{scoreUtil.getRateClass(item.score)}}">{{scoreUtil.getRate(item.score, item.fullScore)}}%</view>
          <view class="score-view-card-rank" wx:if="{{item.classRank || item.gradeRank}}">
            <text class="rank-tag" wx:if="{{item.classRank}}">班{{item.classRank}}</text>
            <text class="rank-tag" wx:if="{{item.gradeRank}}">年{{item.gradeRank}}</text>
          </view>
        </view>
        <view class="score-view-card score-view-card-add" bindtap="openScoreModal">
          <text class="score-view-card-add-icon">+</text>
          <text class="score-view-card-name">添加成绩</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

<view class="modal-mask" wx:if="{{showExamModal}}">
  <view class="modal" catchtap="" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">{{editExamId ? '编辑考试' : '新建考试'}}</view>
      <view class="modal-close" bindtap="closeExamModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <view class="form-label">考试名称 *</view>
        <input class="form-input" placeholder="Exam name" value="{{examForm.name}}" bindinput="onExamFormInput" data-field="name" />
      </view>
      <view class="form-row">
        <view class="form-group">
          <view class="form-label">开始日期</view>
          <picker mode="date" value="{{examForm.startDate}}" bindchange="onExamDatePick" data-field="startDate">
            <view class="form-input picker-input">{{examForm.startDate || '选择日期'}}</view>
          </picker>
        </view>
        <view class="form-group">
          <view class="form-label">结束日期</view>
          <picker mode="date" value="{{examForm.endDate}}" bindchange="onExamDatePick" data-field="endDate">
            <view class="form-input picker-input">{{examForm.endDate || '选择日期'}}</view>
          </picker>
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">备注</view>
        <textarea class="form-textarea" placeholder="Optional notes" value="{{examForm.notes}}" bindinput="onExamFormInput" data-field="notes" maxlength="200"></textarea>
      </view>
      <view class="form-row">
        <view class="form-group">
          <view class="form-label">班级排名</view>
          <input class="form-input" type="number" placeholder="Optional" value="{{examForm.totalClassRank}}" bindinput="onExamFormInput" data-field="totalClassRank" />
        </view>
        <view class="form-group">
          <view class="form-label">年级排名</view>
          <input class="form-input" type="number" placeholder="Optional" value="{{examForm.totalGradeRank}}" bindinput="onExamFormInput" data-field="totalGradeRank" />
        </view>
      </view>
      <view class="form-row">
        <view class="form-group">
          <view class="form-label">班级人数</view>
          <input class="form-input" type="number" placeholder="Optional" value="{{examForm.classTotal}}" bindinput="onExamFormInput" data-field="classTotal" />
        </view>
        <view class="form-group">
          <view class="form-label">年级人数</view>
          <input class="form-input" type="number" placeholder="Optional" value="{{examForm.gradeTotal}}" bindinput="onExamFormInput" data-field="gradeTotal" />
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeExamModal">取消</view>
      <view class="btn btn-primary" bindtap="saveExam">{{editExamId ? '保存' : '创建'}}</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showScoreModal}}">
  <view class="modal" catchtap="" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">{{editSubjectIndex !== null ? '编辑成绩' : '添加成绩'}}</view>
      <view class="modal-close" bindtap="closeScoreModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <view class="form-label">科目 *</view>
        <input class="form-input" placeholder="Subject name" value="{{scoreForm.name}}" bindinput="onScoreFormInput" data-field="name" />
      </view>
      <view class="form-row">
        <view class="form-group">
          <view class="form-label">成绩 *</view>
          <input class="form-input" type="number" placeholder="Score" value="{{scoreForm.score}}" bindinput="onScoreFormInput" data-field="score" />
        </view>
        <view class="form-group">
          <view class="form-label">满分</view>
          <input class="form-input" type="number" placeholder="100" value="{{scoreForm.fullScore}}" bindinput="onScoreFormInput" data-field="fullScore" />
        </view>
      </view>
      <view class="form-row">
        <view class="form-group">
          <view class="form-label">班级排名</view>
          <input class="form-input" type="number" placeholder="Optional" value="{{scoreForm.classRank}}" bindinput="onScoreFormInput" data-field="classRank" />
        </view>
        <view class="form-group">
          <view class="form-label">年级排名</view>
          <input class="form-input" type="number" placeholder="Optional" value="{{scoreForm.gradeRank}}" bindinput="onScoreFormInput" data-field="gradeRank" />
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">备注</view>
        <input class="form-input" placeholder="Notes" value="{{scoreForm.notes}}" bindinput="onScoreFormInput" data-field="notes" />
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeScoreModal">取消</view>
      <view class="btn btn-primary" bindtap="saveSubject">保存</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showConfirmModal}}" bindtap="closeConfirmModal">
  <view class="modal confirm-modal" catchtap="">
    <view class="confirm-icon-wrap {{confirmIconType}}">
      <text>{{confirmIcon}}</text>
    </view>
    <view class="confirm-title">{{confirmTitle}}</view>
    <view class="confirm-message">{{confirmMessage}}</view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeConfirmModal" wx:if="{{confirmShowCancel}}">取消</view>
      <view class="btn {{confirmOkClass}}" bindtap="onConfirmOk">{{confirmOkText}}</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showReportModal}}" bindtap="closeReportModal">
  <view class="modal report-modal" catchtap="">
    <view class="modal-header">
      <view class="modal-title">预览分享报告</view>
      <view class="modal-close" bindtap="closeReportModal">×</view>
    </view>
    <view class="report-preview">
      <canvas canvas-id="reportCanvas" id="reportCanvas" class="report-canvas" style="height:{{reportCanvasHeight || 800}}px;width:375px;" wx:if="{{!reportImage}}"></canvas>
      <image wx:if="{{reportImage}}" src="{{reportImage}}" mode="widthFix" class="report-image" show-menu-by-longpress="true"></image>
      <view class="report-loading" wx:if="{{reportLoading}}">
        <view class="report-loading-text">正在生成报告...</view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeReportModal">取消</view>
      <view class="btn btn-download" bindtap="saveReport" wx:if="{{reportImage}}">保存图片</view>
      <view class="btn btn-share" bindtap="shareReport" wx:if="{{reportImage}}">转发</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showRenameModal}}" bindtap="closeRenameModal">
  <view class="modal" catchtap="" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">重命名档案</view>
      <view class="modal-close" bindtap="closeRenameModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <input class="form-input" placeholder="Rename profile" maxlength="20" value="{{renameValue}}" bindinput="onRenameInput" focus="{{true}}" bindconfirm="confirmRename" />
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeRenameModal">取消</view>
      <view class="btn btn-primary" bindtap="confirmRename">确定</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showChartZoom}}" bindtap="closeChartZoom">
  <view class="modal chart-zoom-modal" catchtap="" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">{{chartZoomTitle}}</view>
      <view class="modal-close" bindtap="closeChartZoom">×</view>
    </view>
    <view class="modal-body chart-zoom-body">
      <block wx:if="{{chartZoomType === 'trend'}}">
        <scroll-view scroll-x class="chart-tabs-scroll">
          <view class="chart-tabs-inner">
            <view class="chart-tab {{zoomSelectedSubject === '' ? 'active' : ''}}" bindtap="zoomSelectSubject" data-subject="">总分</view>
            <view class="chart-tab {{zoomSelectedSubject === item ? 'active' : ''}}"
              wx:for="{{subjectNames}}" wx:key="*this" bindtap="zoomSelectSubject" data-subject="{{item}}">{{item}}</view>
          </view>
        </scroll-view>
        <view class="rank-type-row" wx:if="{{analysisMode === 'rank'}}">
          <view class="rank-type-option {{zoomRankType === 'class' ? 'active' : ''}}" bindtap="zoomSwitchRankType" data-type="class">班级排名</view>
          <view class="rank-type-option {{zoomRankType === 'grade' ? 'active' : ''}}" bindtap="zoomSwitchRankType" data-type="grade">年级排名</view>
        </view>
        <canvas canvas-id="zoomTrendChart" id="zoomTrendChart" class="zoom-trend-canvas"></canvas>
      </block>
      <block wx:if="{{chartZoomType === 'radar'}}">
        <view class="radar-title">当前：<text class="radar-current-name">{{currentExam ? currentExam.name : '未选择'}}</text></view>
        <canvas canvas-id="zoomRadarChart" id="zoomRadarChart" class="zoom-radar-canvas"></canvas>
      </block>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showBatchModal}}" bindtap="closeBatchModal">
  <view class="modal batch-modal" catchtap="noop" catchtouchmove="">
    <view class="modal-header">
      <view class="modal-title">批量填写成绩</view>
      <view class="modal-close" bindtap="closeBatchModal">×</view>
    </view>
    <scroll-view scroll-y class="batch-body" catchtap="noop">
      <view class="batch-header">
        <view class="batch-col batch-col-name">科目</view>
        <view class="batch-col batch-col-score">成绩</view>
        <view class="batch-col batch-col-rank">班排</view>
        <view class="batch-col batch-col-rank">年排</view>
        <view class="batch-col batch-col-del"></view>
      </view>

      <view class="batch-row" wx:for="{{batchList}}" wx:key="index">
        <view class="batch-col batch-col-name">
          <input class="batch-input batch-name-input" placeholder="Subject" value="{{item.name}}" bindinput="onBatchInput" data-index="{{index}}" data-field="name" />
        </view>
        <view class="batch-col batch-col-score">
          <input class="batch-input" type="number" placeholder="Score" value="{{item.score}}" bindinput="onBatchInput" data-index="{{index}}" data-field="score" />
        </view>
        <view class="batch-col batch-col-rank">
          <input class="batch-input" type="number" placeholder="Optional" value="{{item.classRank}}" bindinput="onBatchInput" data-index="{{index}}" data-field="classRank" />
        </view>
        <view class="batch-col batch-col-rank">
          <input class="batch-input" type="number" placeholder="Optional" value="{{item.gradeRank}}" bindinput="onBatchInput" data-index="{{index}}" data-field="gradeRank" />
        </view>
        <view class="batch-col batch-col-del">
          <view class="batch-del-btn" bindtap="removeBatchSubject" data-index="{{index}}">删</view>
        </view>
      </view>

      <view class="batch-add-row">
        <input class="batch-input batch-add-input" placeholder="New subject" value="{{newBatchSubject}}" bindinput="onNewBatchInput" bindconfirm="addBatchSubject" />
        <view class="batch-add-btn" bindtap="addBatchSubject">+ 添加</view>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <view class="btn btn-secondary" bindtap="closeBatchModal">取消</view>
      <view class="btn btn-primary" bindtap="saveBatch">全部保存</view>
    </view>
  </view>
</view>
