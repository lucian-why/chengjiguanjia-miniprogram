/* 去除点击黑色高亮 */
view, text, navigator, image {
  -webkit-tap-highlight-color: transparent;
}

/* ===== 档案选择器 ===== */
.profile-bar {
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
}

.profile-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
}

.profile-picker-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.profile-picker-arrow {
  font-size: 20rpx;
  color: var(--text-secondary);
}

/* ===== 标签页 ===== */
.tabs {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  box-shadow: var(--shadow-soft);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.tab.active {
  background: var(--text-primary);
  color: #fff;
  font-weight: 500;
}

/* ===== 标签内容 ===== */
.tab-content {
  padding: 24rpx;
  padding-bottom: 160rpx;
  min-height: 70vh;
}

/* ===== 考试列表 ===== */
.exam-scroll {
  /* 列表铺满，由页面自然滚动 */
}

.exam-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-soft);
  border: 2rpx solid var(--border-color);
  overflow: hidden;
  transition: all 0.2s;
}

.exam-card.is-active {
  border-color: var(--accent-warm);
  box-shadow: var(--shadow-card);
}

.exam-card.is-excluded {
  opacity: 0.5;
}

.exam-card.is-excluded .exam-name {
  text-decoration: line-through;
}

.exam-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.exam-info {
  flex: 1;
  min-width: 0;
}

.exam-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exam-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.exam-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.exam-edit-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 50%;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-color);
}

.exam-badges {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

/* 考试展开的科目列表 */
.exam-subjects {
  padding: 0 24rpx 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.subject-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(232, 228, 222, 0.5);
}

.subject-row:last-child {
  border-bottom: none;
}

.subject-row-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.subject-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.subject-row-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.subject-row-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.subject-row-score {
  font-size: 30rpx;
  font-weight: 600;
}

.subject-row-full {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.rank-tags {
  display: flex;
  gap: 6rpx;
  margin-left: 8rpx;
}

.rank-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  background: rgba(124, 169, 201, 0.12);
  color: var(--accent-blue);
  border-radius: 8rpx;
}

/* 考试操作按钮 */
.exam-actions {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 24rpx 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.exam-action-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-color);
}

.exam-action-btn.danger {
  color: var(--accent-danger);
  border-color: #fcc;
  background: #fee;
}

/* ===== 底部详情面板 ===== */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 500;
  animation: fadeIn 0.2s ease;
}

.detail-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 80vh;
  background: var(--bg-primary);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 501;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  animation: panelSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

/* 面板左滑退出动画 */
@keyframes panelSlideOutLeft {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(-100%); opacity: 0; }
}

.panel-slide-out-left {
  animation: panelSlideOutLeft 0.25s ease-in forwards;
}

/* 页面从右侧滑入（左滑切换到下一页） */
@keyframes slideInRight {
  from { transform: translateX(30px); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.slide-in-right {
  animation: slideInRight 0.2s ease-out;
}

/* 页面从左侧滑入（右滑切换到上一页） */
@keyframes slideInLeft {
  from { transform: translateX(-30px); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.slide-in-left {
  animation: slideInLeft 0.2s ease-out;
}

/* 页面向左滑出（左滑切换时的旧页面） */
@keyframes slideOutLeft {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(-30px); opacity: 0; }
}

.slide-out-left {
  animation: slideOutLeft 0.2s ease-in forwards;
}

/* 页面向右滑出（右滑切换时的旧页面） */
@keyframes slideOutRight {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(30px); opacity: 0; }
}

.slide-out-right {
  animation: slideOutRight 0.2s ease-in forwards;
}

@keyframes panelSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-panel-header {
  flex-shrink: 0;
  padding: 20rpx 32rpx 16rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-color);
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
}

.detail-panel-handle {
  width: 64rpx;
  height: 8rpx;
  background: var(--border-color);
  border-radius: 4rpx;
  margin: 0 auto 16rpx;
}

.detail-panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.detail-panel-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.detail-panel-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.detail-action-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-color);
}

.detail-action-btn.danger {
  color: var(--accent-danger);
  border-color: #fcc;
  background: #fee;
}

.detail-panel-score {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent-warm);
}

.detail-panel-body {
  flex: 1;
  padding: 24rpx 28rpx 120rpx;
}

/* 分享按钮 */
.share-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #7ca9c9, #9b8dc4);
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 169, 201, 0.3);
}

.exam-date {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.exam-notes {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-style: italic;
  margin-bottom: 20rpx;
}

/* 科目卡片网格 */
.subject-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.subject-card {
  width: calc((100% - 32rpx) / 3);
  background: var(--bg-primary);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.subject-card:active {
  border-color: var(--accent-warm);
}

.delete-subject-btn {
  border: 2rpx dashed var(--border-color);
}

.subject-card-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.note-icon {
  font-size: 20rpx;
  margin-left: 4rpx;
  vertical-align: middle;
}

.subject-card-score {
  font-size: 44rpx;
  font-weight: 600;
}

.subject-card-score.good { color: var(--accent-green); }
.subject-card-score.normal { color: var(--text-primary); }
.subject-card-score.bad { color: var(--accent-danger); }

.subject-card-rank {
  margin-top: 6rpx;
}

.add-subject-btn {
  width: calc((100% - 32rpx) / 3);
  background: var(--bg-primary);
  border: 2rpx dashed var(--border-color);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* 新建考试按钮 */
.new-exam-btn {
  position: fixed;
  bottom: 32rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 64rpx;
  background: var(--text-primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(45, 42, 38, 0.2);
  z-index: 50;
}

.new-exam-btn:active {
  opacity: 0.9;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  opacity: 0.7;
}

/* ===== 卡片 ===== */
.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-color);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: var(--accent-warm);
  border-radius: 3rpx;
}

/* ===== 成绩分析 ===== */
.analysis-tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.analysis-tab {
  padding: 12rpx 24rpx;
  border: 1rpx solid var(--border-color);
  background: var(--bg-card);
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.analysis-tab.active {
  background: var(--text-primary);
  color: #fff;
  border-color: var(--text-primary);
}

/* 科目 tab 横向滚动 */
.chart-tabs-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.chart-tabs-inner {
  display: inline-flex;
  gap: 8rpx;
}

.chart-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  border: 1rpx solid var(--border-color);
  background: var(--bg-card);
  border-radius: 28rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.chart-tab.active {
  background: var(--text-primary);
  color: #fff;
  border-color: var(--text-primary);
}

/* 排名类型切换 */
.rank-type-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.rank-type-option {
  padding: 10rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 28rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-card);
}

.rank-type-option.active {
  background: var(--accent-blue);
  color: #fff;
  border-color: var(--accent-blue);
}

/* 图表 Canvas */
.trend-canvas {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.radar-canvas {
  width: 100%;
  height: 500rpx;
  border-radius: 12rpx;
}

.radar-summary {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.radar-summary-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #faf8f5;
}

.radar-summary-item.best {
  background: rgba(76, 175, 80, 0.08);
}

.radar-summary-item.worst {
  background: rgba(244, 67, 54, 0.06);
}

.radar-summary-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.radar-summary-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-right: 8rpx;
}

.radar-summary-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.radar-summary-detail {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.radar-summary-rate {
  font-size: 24rpx;
  font-weight: 700;
  margin-left: 8rpx;
}

.best-rate {
  color: #4CAF50;
}

.worst-rate {
  color: #E8643C;
}

.chart-empty {
  text-align: center;
  padding: 40rpx 20rpx;
}

.chart-empty-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
  opacity: 0.5;
}

.chart-empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 雷达图 */
.radar-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.radar-compare {
  margin-bottom: 16rpx;
}

.radar-compare-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.compare-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid var(--border-color);
  background: var(--bg-card);
  font-size: 22rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.compare-chip.current {
  border-color: transparent;
  background: rgba(232, 168, 124, 0.15);
  color: #c07a50;
  font-weight: 600;
}

.compare-chip.selected {
  border-color: var(--accent-warm);
  background: rgba(232, 168, 124, 0.1);
  color: var(--text-primary);
  font-weight: 500;
}

.compare-chip.disabled {
  opacity: 0.4;
}

.radar-hint {
  font-size: 20rpx;
  color: var(--text-secondary);
  opacity: 0.6;
}

/* 图表卡片（为放大按钮定位） */
.chart-card {
  position: relative;
}

/* 图表放大按钮 */
.chart-zoom-btn {
  position: absolute;
  top: -28rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  z-index: 5;
}

.chart-zoom-btn:active {
  background: var(--bg-primary);
}

/* 放大弹窗 */
.chart-zoom-modal {
  max-height: 90vh;
}

.chart-zoom-body {
  padding: 24rpx 28rpx;
}

.zoom-trend-canvas {
  width: 100%;
  height: 700rpx;
  border-radius: 12rpx;
}

.zoom-radar-canvas {
  width: 100%;
  height: 800rpx;
  border-radius: 12rpx;
}

/* ===== 设置页 ===== */
.setting-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.profile-list {
  margin-bottom: 16rpx;
}

.profile-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.profile-item:last-child {
  border-bottom: none;
}

.profile-item.is-active {
  background: rgba(232, 168, 124, 0.06);
  border-radius: 12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.profile-item-info {
  flex: 1;
  min-width: 0;
}

.profile-item-name {
  font-weight: 500;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.active-badge {
  font-size: 20rpx;
  background: var(--accent-green);
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.profile-item-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.profile-item-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.profile-share-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #7ca9c9, #9b8dc4);
  color: #fff;
  border-radius: 28rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.profile-action-btn {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
}

.profile-action-btn.danger {
  color: var(--accent-danger);
  border-color: #fcc;
}

/* 新建档案 */
.add-profile-area {
  margin-top: 12rpx;
}

.add-profile-btn {
  display: inline-flex;
  padding: 12rpx 28rpx;
  background: var(--accent-green);
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.add-profile-input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.add-profile-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  background: var(--bg-primary);
}

.add-profile-confirm {
  padding: 14rpx 28rpx;
  background: var(--accent-green);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.add-profile-cancel {
  padding: 14rpx 28rpx;
  background: var(--bg-primary);
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 设置行 */
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-row-left {
  flex: 1;
}

.setting-label {
  font-weight: 500;
  font-size: 28rpx;
}

.setting-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.setting-btn {
  padding: 12rpx 28rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  flex-shrink: 0;
}

.setting-btn.green {
  background: var(--accent-green);
  color: #fff;
  border-color: var(--accent-green);
}

/* ===== 连续创建提示条 ===== */
.continuous-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background: rgba(76, 175, 80, 0.08);
  border-bottom: 1rpx solid rgba(76, 175, 80, 0.15);
}

.continuous-banner-text {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

.continuous-banner-actions {
  display: flex;
  gap: 12rpx;
}

.continuous-finish-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #4CAF50;
  border: 1rpx solid #4CAF50;
  border-radius: 20rpx;
  background: transparent;
}

.continuous-finish-btn:active {
  background: rgba(76, 175, 80, 0.1);
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  animation: fadeIn 0.2s ease;
}

.modal {
  background: var(--bg-card);
  border-radius: 28rpx;
  width: 100%;
  max-width: 640rpx;
  max-height: 85vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-secondary);
}

.modal-body {
  padding: 28rpx 32rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 28rpx;
}

/* 表单 */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--bg-primary);
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--accent-warm);
}

.picker-input {
  color: var(--text-secondary);
  line-height: 72rpx;
}

.form-textarea {
  width: 100%;
  padding: 18rpx 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 36rpx;
  background: var(--bg-primary);
  height: 120rpx;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-row .form-group {
  flex: 1;
}

/* 按钮 */
.btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: var(--text-primary);
  color: #fff;
}

.btn-secondary {
  background: var(--bg-primary);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.btn-download {
  background: linear-gradient(135deg, #7ca9c9, #9b8dc4);
  color: #fff;
}

.btn-share {
  background: #07c160;
  color: #fff;
}

/* 确认弹窗 */
.confirm-modal {
  max-width: 560rpx;
  text-align: center;
}

.confirm-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  font-size: 48rpx;
}

.confirm-icon-wrap.danger {
  background: rgba(232, 138, 138, 0.12);
}

.confirm-icon-wrap.success {
  background: rgba(76, 175, 80, 0.12);
}

.confirm-icon-wrap.info {
  background: rgba(66, 165, 245, 0.12);
}

.confirm-icon-wrap.warning {
  background: rgba(255, 152, 0, 0.12);
}

.confirm-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--text-primary);
}

.confirm-message {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 28rpx;
  white-space: pre-line;
}

/* 报告预览 */
.report-modal {
  max-width: 640rpx;
}

.report-preview {
  margin: 16rpx 0;
  text-align: center;
  min-height: 200rpx;
  position: relative;
}

.report-canvas {
  width: 100%;
  height: 800rpx;
}

.report-image {
  width: 100%;
  border-radius: 16rpx;
}

.report-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
}

.report-loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
